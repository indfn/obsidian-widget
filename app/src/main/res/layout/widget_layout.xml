<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Daily Note"
            android:textColor="@color/obsidian_text"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium" />

        <ImageButton
            android:id="@+id/widget_settings"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            android:src="@android:drawable/ic_menu_manage"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Note Preview (no checklist) -->
    <TextView
        android:id="@+id/widget_note_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:text="@string/no_vault_selected"
        android:textColor="@color/obsidian_text_secondary"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp"
        android:maxLines="10"
        android:ellipsize="end"
        android:visibility="gone" />

    <!-- Checklist -->
    <ListView
        android:id="@+id/widget_checklist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"
        android:scrollbars="none"
        android:fadingEdge="vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:clipToPadding="false" />

    <!-- Bottom Buttons -->
    <LinearLayout
        android:id="@+id/widget_button_bar"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/widget_btn_capture"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/button_background"
            android:text="Capture"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium" />

        <ImageButton
            android:id="@+id/widget_add"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/button_background"
            android:contentDescription="Add to note"
            android:src="@drawable/ic_add"
            android:scaleType="centerInside"
            android:padding="7dp" />
    </LinearLayout>

</LinearLayout>
