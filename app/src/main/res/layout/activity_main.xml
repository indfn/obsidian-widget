<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/obsidian_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Obsidian Widget"
            android:textColor="@color/obsidian_text"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_instructions"
            android:textColor="@color/obsidian_text_secondary"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="36dp" />

        <!-- Vault Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vault"
            android:textColor="@color/obsidian_text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="36dp">

            <TextView
                android:id="@+id/vault_path_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No vault selected"
                android:textColor="@color/obsidian_text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_select_vault"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/button_background"
                android:text="Select"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/obsidian_text_secondary"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
