<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/obsidian_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure Widget"
            android:textColor="@color/obsidian_text"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="36dp" />

        <!-- Vault Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vault"
            android:textColor="@color/obsidian_text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/config_vault_path"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No vault selected"
                android:textColor="@color/obsidian_text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/config_select_vault"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/button_background"
                android:text="Select"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />
        </LinearLayout>

        <!-- Note Mode Toggle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/note_mode_label"
            android:textColor="@color/obsidian_text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/config_note_mode_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:orientation="horizontal"
            android:padding="14dp"
            android:layout_marginBottom="20dp">

            <RadioButton
                android:id="@+id/config_radio_daily"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/mode_daily_note"
                android:textColor="@color/obsidian_text"
                android:textSize="14sp"
                android:buttonTint="@color/obsidian_primary" />

            <RadioButton
                android:id="@+id/config_radio_pinned"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/mode_specific_note"
                android:textColor="@color/obsidian_text"
                android:textSize="14sp"
                android:buttonTint="@color/obsidian_primary" />
        </RadioGroup>

        <!-- Pinned Notes Selection -->
        <LinearLayout
            android:id="@+id/config_pinned_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notes"
                android:textColor="@color/obsidian_text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/config_note_list_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/config_add_note"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/button_outline"
                android:text="+ Add Note"
                android:textColor="@color/obsidian_text"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Daily Notes Folder -->
        <LinearLayout
            android:id="@+id/config_daily_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Notes Subfolder"
                android:textColor="@color/obsidian_text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/config_daily_folder"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_background"
                android:hint="@string/daily_notes_hint"
                android:textColor="@color/obsidian_text"
                android:textColorHint="@color/obsidian_text_secondary"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/date_format_label"
                android:textColor="@color/obsidian_text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/config_date_format"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_background"
                android:text="yyyy-MM-dd"
                android:textColor="@color/obsidian_text"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text" />
        </LinearLayout>

        <!-- Show Buttons Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="36dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show widget buttons"
                android:textColor="@color/obsidian_text"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/config_show_buttons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/obsidian_primary"
                android:trackTint="@color/obsidian_text_secondary" />
        </LinearLayout>

        <!-- Sort Unchecked First Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="36dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sort unchecked first"
                android:textColor="@color/obsidian_text"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/config_sort_unchecked"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/obsidian_primary"
                android:trackTint="@color/obsidian_text_secondary" />
        </LinearLayout>

        <!-- Widget Transparency -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Widget Opacity"
            android:textColor="@color/obsidian_text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="36dp">

            <SeekBar
                android:id="@+id/config_transparency"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="100"
                android:progressTint="@color/obsidian_primary"
                android:thumbTint="@color/obsidian_primary" />

            <TextView
                android:id="@+id/config_transparency_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="100%"
                android:textColor="@color/obsidian_text"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/config_save"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/button_background"
            android:text="@string/save_widget"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>
</ScrollView>
